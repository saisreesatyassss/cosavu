# Supabase Credentials (Client-side)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Firebase Credentials (Client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# Cosavu API Base URLs
NEXT_PUBLIC_COSAVU_API_BASE_URL=https://api.cosavu.com
NEXT_PUBLIC_COSAVU_DATA_API_BASE_URL=https://dataapi.cosavu.com

# Administrative Credentials
COSAVU_DOMAIN_PASSWORD=your_custom_domain_login_password
DATAMAN_CONSOLE_PASSWORD=your_dataman_console_auth_password
COSAVU_STATS_API_KEY=your_cosavu_stats_retrieval_api_key

# Admin Tokens for data tenant operations
NEXT_PUBLIC_COSAVU_ADMIN_TOKEN=your_public_admin_token
COSAVU_ADMIN_TOKEN=your_backend_admin_token
COSAVU_DATA_ADMIN_TOKEN=your_backend_data_admin_token
DATAAPI_ADMIN_TOKEN=your_data_api_admin_token

# Stripe Billing Credentials
STRIPE_SECRET_KEY=your_stripe_secret_key
